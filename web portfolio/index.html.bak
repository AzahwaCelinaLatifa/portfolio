      <div class="tile"><div class="tile-spot"></div><div class="t-num">01</div><div class="t-ph"><svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg><span>Screenshot</span></div><div class="t-ov"><div class="t-tags"><span class="t-tag">HTML</span><span class="t-tag">CSS</span><span class="t-tag">JS</span></div><div class="t-title" data-i18n="p1t">Website Sekolah</div><div class="t-desc" data-i18n="p1d">Website profil SMK responsif dengan galeri, berita, dan halaman kontak interaktif.</div><a href="#" class="t-link" data-i18n="vp">Lihat Proyek →</a></div></div>
      <div class="tile"><div class="tile-spot"></div><div class="t-num">02</div><div class="t-ph"><svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="12" cy="12" r="9"/><path d="M12 3v9l4 4"/></svg><span>Screenshot</span></div><div class="t-ov"><div class="t-tags"><span class="t-tag">Cisco</span><span class="t-tag">Packet Tracer</span></div><div class="t-title" data-i18n="p2t">Simulasi Jaringan LAN</div><div class="t-desc" data-i18n="p2d">Simulasi LAN 3 subnet dengan VLAN, routing, dan troubleshooting komprehensif.</div><a href="#" class="t-link" data-i18n="vp">Lihat Proyek →</a></div></div>
      <div class="tile"><div class="tile-spot"></div><div class="t-num">03</div><div class="t-ph"><svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg><span>Screenshot</span></div><div class="t-ov"><div class="t-tags"><span class="t-tag">Canva</span><span class="t-tag">Branding</span></div><div class="t-title" data-i18n="p3t">Brand Identity OSIS</div><div class="t-desc" data-i18n="p3d">Identitas visual lengkap: logo, poster, dan template sosmed untuk OSIS sekolah.</div><a href="#" class="t-link" data-i18n="vp">Lihat Proyek →</a></div></div>
      <div class="tile"><div class="tile-spot"></div><div class="t-num">04</div><div class="t-ph"><svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M4 4h16v16H4zM4 9h16M9 9v11"/></svg><span>Screenshot</span></div><div class="t-ov"><div class="t-tags"><span class="t-tag">PHP</span><span class="t-tag">MySQL</span><span class="t-tag">Bootstrap</span></div><div class="t-title" data-i18n="p4t">Sistem Inventaris</div><div class="t-desc" data-i18n="p4d">Aplikasi manajemen inventaris dengan fitur CRUD, laporan stok, dan UI intuitif.</div><a href="#" class="t-link" data-i18n="vp">Lihat Proyek →</a></div></div>
    </div>
  </div>
</section>

<!-- ═══ CV ═══ -->
<section id="cv">
  <svg id="cv-svg-bg" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%"></svg>
  <div class="sec-inner">
    <div class="cv-pr"><button class="sv-btn" onclick="window.print()" data-i18n="pcv">Cetak / PDF</button></div>
    <div class="cv-mast rv">
      <div><div class="cv-mn">Azahwa Celina Latifa</div><div class="cv-mr" data-i18n="cvr">SISWA SMK · TEKNIK KOMPUTER &amp; JARINGAN · CALON WEB DEVELOPER</div></div>
      <div class="cv-md" data-i18n="cvd">Semarang · 2025</div>
    </div>
    <div class="cv-body rv">
      <div>
        <div class="cv-aside-ph"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg><span>Foto Profesional</span><span style="font-size:8px;opacity:.6">Ganti dengan &lt;img&gt;</span></div>
        <div class="cv-ab"><div class="cv-at" data-i18n="cvct">Kontak</div><div class="cv-ai"><span class="sv-dot"></span>azahwacelinalatifa@gmail.com</div><div class="cv-ai"><span class="sv-dot"></span>+62 812-2519-4448</div><div class="cv-ai"><span class="sv-dot"></span>Semarang, Indonesia</div><div class="cv-ai"><span class="sv-dot"></span>github.com/AzahwaCelina Latifa</div></div>
        <div class="cv-ab"><div class="cv-at" data-i18n="cvpt">Data Pribadi</div><div class="cv-ai"><span class="sv-dot"></span><span data-i18n="cvdob">Semarang, 2 Desember 2008</span></div><div class="cv-ai"><span class="sv-dot"></span><span data-i18n="cvre">Islam</span></div><div class="cv-ai"><span class="sv-dot"></span><span data-i18n="cvci">Indonesia</span></div></div>
        <div class="cv-ab"><div class="cv-at" data-i18n="cvst">Keahlian</div>
          <div class="cv-sr"><div class="cv-sn">HTML &amp; CSS</div><div class="cv-ds"><div class="cv-d on"></div><div class="cv-d on"></div><div class="cv-d on"></div><div class="cv-d on"></div><div class="cv-d"></div></div></div>
          <div class="cv-sr"><div class="cv-sn">JavaScript</div><div class="cv-ds"><div class="cv-d on"></div><div class="cv-d on"></div><div class="cv-d on"></div><div class="cv-d"></div><div class="cv-d"></div></div></div>
          <div class="cv-sr"><div class="cv-sn">Cisco Packet Tracer</div><div class="cv-ds"><div class="cv-d on"></div><div class="cv-d on"></div><div class="cv-d on"></div><div class="cv-d on"></div><div class="cv-d"></div></div></div>
          <div class="cv-sr"><div class="cv-sn">Canva / Photoshop</div><div class="cv-ds"><div class="cv-d on"></div><div class="cv-d on"></div><div class="cv-d on"></div><div class="cv-d on"></div><div class="cv-d on"></div></div></div>
          <div class="cv-sr"><div class="cv-sn">PHP &amp; MySQL</div><div class="cv-ds"><div class="cv-d on"></div><div class="cv-d on"></div><div class="cv-d"></div><div class="cv-d"></div><div class="cv-d"></div></div></div>
        </div>
      </div>
      <div>
        <div class="cv-main-block"><div class="cv-mbt" data-i18n="cvpft">Profil</div><p class="cv-ed" data-i18n="cvpf">Siswa SMK jurusan Sistem Informasi Jaringan dan Aplikasi dengan ketertarikan kuat pada pengembangan web dan desain UI/UX. Berpengalaman dalam pembuatan website, desain grafis, dan konfigurasi jaringan komputer. Termotivasi untuk terus belajar dan berkontribusi dalam ekosistem teknologi digital Indonesia.</p></div>
        <div class="cv-main-block"><div class="cv-mbt" data-i18n="cvedt">Pendidikan</div>
          <div class="cv-ent"><div class="cv-er"><div><div class="cv-et">SMK Negeri 7 Semarang</div><div class="cv-es">Teknik Komputer &amp; Jaringan</div></div><div class="cv-ey">2022–kini</div></div></div>
          <div class="cv-ent"><div class="cv-er"><div><div class="cv-et">SMP Negeri 5 Semarang</div></div><div class="cv-ey">2019–2022</div></div></div>
          <div class="cv-ent"><div class="cv-er"><div><div class="cv-et">SD Negeri Sukorejo 1</div></div><div class="cv-ey">2013–2019</div></div></div>
        </div>
        <div class="cv-main-block"><div class="cv-mbt" data-i18n="cvext">Pengalaman &amp; Kegiatan</div>
          <div class="cv-ent"><div class="cv-er"><div><div class="cv-et" data-i18n="e1t">Juara 2 — LKS Web Design Tingkat Kota</div><div class="cv-es">Dinas Pendidikan Kota Semarang</div></div><div class="cv-ey">2024</div></div><div class="cv-ed" data-i18n="e1d">Meraih juara 2 dalam lomba desain web tingkat kota dengan website company profile responsif dan estetis.</div></div>
          <div class="cv-ent"><div class="cv-er"><div><div class="cv-et" data-i18n="e2t">Ketua Divisi IT — OSIS SMK Negeri 4</div></div><div class="cv-ey">2023–2024</div></div><div class="cv-ed" data-i18n="e2d">Memimpin tim IT dalam pengelolaan media sosial, dokumentasi, dan konten digital sekolah.</div></div>
          <div class="cv-ent"><div class="cv-er"><div><div class="cv-et" data-i18n="e3t">PKL — CV Maju Teknologi</div><div class="cv-es">Semarang</div></div><div class="cv-ey">Jul–Sep 2024</div></div><div class="cv-ed" data-i18n="e3d">Maintenance jaringan, troubleshooting hardware, dan pengembangan website internal perusahaan.</div></div>
          <div class="cv-ent"><div class="cv-er"><div><div class="cv-et" data-i18n="e4t">Peserta Hackathon Youth Tech 2024</div><div class="cv-es">ITB</div></div><div class="cv-ey">Nov 2024</div></div><div class="cv-ed" data-i18n="e4d">Membangun prototipe aplikasi sistem informasi desa berbasis web dalam 24 jam.</div></div>
        </div>
        <div class="cv-qb"><div class="cv-qt" data-i18n="cvq">"Teknologi adalah alat — kreativitas adalah jiwa di baliknya. Saya hadir untuk menggabungkan keduanya."</div><div class="cv-qa">— Azahwa Celina Latifa</div></div>
      </div>
    </div>
  </div>
</section>

<footer><span data-i18n="ft">© 2025 Azahwa Celina Latifa · Dibuat dengan ❤ dari Semarang</span></footer>

<script>
/* ── i18n ── */
const T={
  id:{nh:"Beranda",na:"Tentang",nsk:"Keahlian",np:"Portofolio",nc:"CV",havl:"Tersedia untuk Peluang Baru",htag:"Calon Web Developer & IT Enthusiast\nTertarik pada UI/UX dan Jaringan",hdesc:"Saya adalah siswa SMK yang bersemangat dalam dunia teknologi dan pengembangan web. Saya percaya desain yang baik bukan hanya soal tampilan, tapi tentang pengalaman. Terus belajar, terus berkarya.",t1:"📍 Semarang",t2:"🎓 SMK SIJA",t3:"💻 Web Dev",drag:"↕ Tarik kartu",bw:"Lihat Karya",bc:"Unduh CV",sc:"scroll",lab_a:"001 — Tentang Saya",a_ttl:"Mengenal\nLebih Dekat",a_sub:"Seorang pelajar, desainer, dan pembangun hal-hal digital.",af_t:"Keluarga & Latar",af_p:"Lahir dan besar di Semarang, Jawa Barat. Anak pertama dari dua bersaudara dalam keluarga sederhana yang mengutamakan pendidikan. Ayah saya seorang teknisi — itulah awal ketertarikan saya pada dunia teknis.",ae_t:"Pendidikan",ahob_t:"Hobi & Minat",h1:"Desain grafis & UI/UX exploration",h2:"Membaca artikel teknologi",h3:"Hackathon & lomba IT",h4:"Fotografi urban",h5:"Gitar akustik",ac_t:"Tujuan Karier",ac_p:"Menjadi Full-Stack Developer yang menciptakan solusi digital berdampak, berkontribusi di perusahaan teknologi inovatif sambil terus bertumbuh.",astr_t:"Kelebihan Diri",sft:"SOFT SKILLS",hrd:"HARD SKILLS",ss1:"Cepat Belajar",ss2:"Kreatif",ss3:"Detail-Oriented",ss4:"Kerja Tim",ss5:"Adaptif",ss6:"Komunikatif",skt:"Apa yang\nSaya Kuasai",sksub:"— Keahlian Teknis & Kreatif",pttl:"Karya &\nProyek",ptm1:"4 proyek selesai",ptm2:"2024 – 2025",vp:"Lihat Proyek →",p1t:"Website Sekolah",p1d:"Website profil SMK responsif dengan galeri, berita, dan halaman kontak interaktif.",p2t:"Simulasi Jaringan LAN",p2d:"Simulasi LAN 3 subnet dengan VLAN, routing, dan troubleshooting komprehensif.",p3t:"Brand Identity OSIS",p3d:"Identitas visual lengkap: logo, poster, dan template sosmed untuk OSIS sekolah.",p4t:"Sistem Inventaris",p4d:"Aplikasi manajemen inventaris dengan fitur CRUD, laporan stok, dan UI intuitif.",pcv:"Cetak / PDF",cvr:"SISWA SMK · Sistem Informasi Jaringan dan Aplikasi · CALON WEB DEVELOPER",cvd:"Semarang · 2025",cvct:"Kontak",cvpt:"Data Pribadi",cvdob:"Semarang, 2 Desember 2008",cvre:"Islam",cvci:"Indonesia",cvst:"Keahlian",cvpft:"Profil",cvpf:"Siswa SMK jurusan Sistem Informasi Jaringan dan Aplikasi dengan ketertarikan kuat pada pengembangan web dan desain UI/UX. Berpengalaman dalam pembuatan website, desain grafis, dan konfigurasi jaringan komputer. Termotivasi untuk terus belajar.",cvedt:"Pendidikan",cvext:"Pengalaman & Kegiatan",e1t:"Juara 2 — LKS Web Design Tingkat Kota",e1d:"Meraih juara 2 dalam lomba desain web tingkat kota dengan website company profile responsif.",e2t:"Ketua Divisi IT — OSIS SMK Negeri 4",e2d:"Memimpin tim IT dalam pengelolaan media sosial, dokumentasi, dan konten digital sekolah.",e3t:"PKL — CV Maju Teknologi",e3d:"Maintenance jaringan, troubleshooting hardware, dan pengembangan website internal perusahaan.",e4t:"Peserta Hackathon Youth Tech 2024",e4d:"Membangun prototipe aplikasi sistem informasi desa berbasis web dalam 24 jam.",cvq:'"Teknologi adalah alat — kreativitas adalah jiwa di baliknya. Saya hadir untuk menggabungkan keduanya."',ft:"© 2025 Azahwa Celina Latifa · Dibuat dengan ❤ dari Semarang"},
  en:{nh:"Home",na:"About",nsk:"Skills",np:"Portfolio",nc:"CV",havl:"Open to New Opportunities",htag:"Aspiring Web Developer & IT Enthusiast\nPassionate about UI/UX and Networking",hdesc:"I'm a vocational high school student passionate about technology and web development. I believe good design isn't just about looks — it's about experience. Always learning, always building.",t1:"📍 Semarang",t2:"🎓 SMK SIJA",t3:"💻 Web Dev",drag:"↕ Drag card",bw:"View Work",bc:"Download CV",sc:"scroll",lab_a:"001 — About Me",a_ttl:"Getting to\nKnow Me",a_sub:"A student, designer, and builder of digital things.",af_t:"Background",af_p:"Born and raised in Semarang, West Java. Eldest of two siblings in a modest family that values education. My father is a technician — the origin of my love for all things technical.",ae_t:"Education",ahob_t:"Hobbies & Interests",h1:"Graphic design & UI/UX exploration",h2:"Reading tech articles",h3:"Hackathons & IT competitions",h4:"Urban photography",h5:"Acoustic guitar",ac_t:"Career Goals",ac_p:"To become a Full-Stack Developer creating impactful digital solutions, contributing to innovative tech companies while continuing to grow.",astr_t:"Personal Strengths",sft:"SOFT SKILLS",hrd:"HARD SKILLS",ss1:"Fast Learner",ss2:"Creative",ss3:"Detail-Oriented",ss4:"Team Player",ss5:"Adaptable",ss6:"Communicative",skt:"What I\nExcel At",sksub:"— Technical & Creative Skills",pttl:"Works &\nProjects",ptm1:"4 projects complete",ptm2:"2024 – 2025",vp:"View Project →",p1t:"School Website",p1d:"Responsive SMK profile website with gallery, news, and interactive contact page.",p2t:"LAN Network Simulation",p2d:"3-subnet LAN simulation with VLAN, routing, and comprehensive troubleshooting.",p3t:"OSIS Brand Identity",p3d:"Full visual identity: logo, posters, and social media templates for student council.",p4t:"Inventory System",p4d:"Inventory management app with CRUD, stock reports, and intuitive UI.",pcv:"Print / PDF",cvr:"STUDENT · COMPUTER & NETWORK ENGINEERING · ASPIRING WEB DEVELOPER",cvd:"Semarang · 2025",cvct:"Contact",cvpt:"Personal Data",cvdob:"Semarang, March 15 2007",cvre:"Islam",cvci:"Indonesian",cvst:"Skills",cvpft:"Profile",cvpf:"Vocational high school student majoring in Computer & Network Engineering with a strong interest in web development and UI/UX design. Experienced in website creation, graphic design, and network configuration. Motivated to keep learning.",cvedt:"Education",cvext:"Experience & Activities",e1t:"2nd Place — City Level Web Design Competition",e1d:"Achieved 2nd place building a responsive, aesthetic company profile website.",e2t:"IT Division Head — Student Council",e2d:"Led IT team in social media management, documentation, and digital content creation.",e3t:"Internship — CV Maju Teknologi",e3d:"Network maintenance, hardware troubleshooting, and internal website development.",e4t:"Participant — Youth Tech 2024 Hackathon",e4d:"Built a prototype web-based village information system in 24 hours.",cvq:'"Technology is the tool — creativity is the soul behind it. I am here to bring both together."',ft:"© 2025 Azahwa Celina Latifa · Made with ❤ from Semarang"}
};
let lang='id';
function applyLang(l){lang=l;document.querySelectorAll('[data-i18n]').forEach(el=>{const k=el.getAttribute('data-i18n');if(T[l][k])el.innerHTML=T[l][k].replace(/\n/g,'<br>')})}
document.getElementById('lsel').addEventListener('change',e=>applyLang(e.target.value));

/* ── THEME ── */
const thT=document.getElementById('thT');
thT.addEventListener('change',()=>{
  const d=thT.checked;
  document.documentElement.setAttribute('data-theme',d?'dark':'light');
  document.getElementById('tlb').textContent=d?'Dark':'Light';
  initSkillsCanvas(); initPortfolioCanvas(); drawCVTopo();
});

/* ── MOBILE MENU ── */
function toggleMob(){document.getElementById('mm').classList.toggle('open');document.getElementById('hbg').classList.toggle('open')}

/* ── ACTIVE NAV ── */
const allSecs=document.querySelectorAll('section[id]');
const navAs=document.querySelectorAll('.nl a,.mm a');
window.addEventListener('scroll',()=>{let c='';allSecs.forEach(s=>{if(window.scrollY>=s.offsetTop-80)c=s.id});navAs.forEach(a=>a.classList.toggle('act',a.getAttribute('href')==='#'+c))},{passive:true});

/* ════════════════════════════════
   BG 1: HOME — Animated Particles
════════════════════════════════ */
(function(){
  const cvs=document.getElementById('home-canvas');
  const ctx=cvs.getContext('2d');
  let W,H,pts=[];
  function resize(){W=cvs.width=cvs.offsetWidth;H=cvs.height=cvs.offsetHeight}
  function isDark(){return document.documentElement.getAttribute('data-theme')==='dark'}
  function mkPts(){pts=[];const n=Math.min(60,Math.floor(W*H/18000));for(let i=0;i<n;i++)pts.push({x:Math.random()*W,y:Math.random()*H,r:Math.random()*1.5+.4,vx:(Math.random()-.5)*.3,vy:(Math.random()-.5)*.3,o:Math.random()*.5+.2})}
  function draw(){
    ctx.clearRect(0,0,W,H);
    const clr=isDark()?'240,239,232':'17,17,16';
    pts.forEach(p=>{
      p.x+=p.vx;p.y+=p.vy;
      if(p.x<0)p.x=W;if(p.x>W)p.x=0;if(p.y<0)p.y=H;if(p.y>H)p.y=0;
      ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fillStyle=`rgba(${clr},${p.o})`;ctx.fill();
    });
    // connect nearby
    for(let i=0;i<pts.length;i++)for(let j=i+1;j<pts.length;j++){
      const dx=pts[i].x-pts[j].x,dy=pts[i].y-pts[j].y,d=Math.sqrt(dx*dx+dy*dy);
      if(d<100){ctx.beginPath();ctx.moveTo(pts[i].x,pts[i].y);ctx.lineTo(pts[j].x,pts[j].y);ctx.strokeStyle=`rgba(${clr},${.12*(1-d/100)})`;ctx.lineWidth=.5;ctx.stroke()}
    }
    requestAnimationFrame(draw);
  }
  window.addEventListener('resize',()=>{resize();mkPts()},true);
  resize();mkPts();draw();
})();

/* ════════════════════════════════
   BG 2: ABOUT — Floating Paper Sheets
════════════════════════════════ */
(function(){
  const bg=document.getElementById('about-bg');
  if(!bg)return;
  const sheets=[];
  const n=7;
  for(let i=0;i<n;i++){
    const d=document.createElement('div');
    d.className='paper-fold';
    const w=Math.random()*180+80,h=Math.random()*240+100;
    const x=Math.random()*110-10,y=Math.random()*110-10;
    const rot=Math.random()*40-20;
    d.style.cssText=`width:${w}px;height:${h}px;left:${x}%;top:${y}%;transform:rotate(${rot}deg);border:1px solid var(--text);background:var(--bg3);border-radius:2px`;
    bg.appendChild(d);
    sheets.push({el:d,x,y,rot,spd:Math.random()*.15+.05,amp:Math.random()*3+1,t:Math.random()*Math.PI*2});
  }
  // Add ruled lines effect
  const liner=document.createElement('div');
  liner.style.cssText=`position:absolute;inset:0;background-image:repeating-linear-gradient(transparent,transparent 27px,var(--border) 28px);opacity:.15;pointer-events:none`;
  bg.appendChild(liner);

  function animate(){
    sheets.forEach(s=>{
      s.t+=s.spd*.01;
      const dy=Math.sin(s.t)*s.amp;
      const dr=Math.cos(s.t*.7)*.5;
      s.el.style.transform=`rotate(${s.rot+dr}deg) translateY(${dy}px)`;
    });
    requestAnimationFrame(animate);
  }
  animate();
})();

/* ════════════════════════════════
   BG 3: SKILLS — Animated Dot Matrix
════════════════════════════════ */
function initSkillsCanvas(){
  const cvs=document.getElementById('skills-canvas');
  if(!cvs)return;
  const ctx=cvs.getContext('2d');
  let W,H,t=0;
  function isDark(){return document.documentElement.getAttribute('data-theme')==='dark'}
  function resize(){W=cvs.width=cvs.offsetWidth;H=cvs.height=cvs.offsetHeight}
  function draw(){
    ctx.clearRect(0,0,W,H);
    const gap=28,clr=isDark()?'240,239,232':'17,17,16';
    const cols=Math.ceil(W/gap),rows=Math.ceil(H/gap);
    for(let r=0;r<rows;r++)for(let c=0;c<cols;c++){
      const x=c*gap+gap/2,y=r*gap+gap/2;
      const dist=Math.sqrt((x-W/2)**2+(y-H/2)**2);
      const wave=Math.sin(dist*.02-t*.8)*.5+.5;
      const radius=wave*2.8+.4;
      const alpha=wave*.35+.05;
      ctx.beginPath();ctx.arc(x,y,radius,0,Math.PI*2);
      ctx.fillStyle=`rgba(${clr},${alpha})`;ctx.fill();
    }
    t+=.04;requestAnimationFrame(draw);
  }
  resize();draw();
  window.addEventListener('resize',resize,true);
}
initSkillsCanvas();

/* ════════════════════════════════
   BG 4: PORTFOLIO — Aurora / Orbs
════════════════════════════════ */
function initPortfolioCanvas(){
  const cvs=document.getElementById('portfolio-canvas');
  if(!cvs)return;
  const ctx=cvs.getContext('2d');
  let W,H,t=0;
  function isDark(){return document.documentElement.getAttribute('data-theme')==='dark'}
  function resize(){W=cvs.width=cvs.offsetWidth;H=cvs.height=cvs.offsetHeight}
  const orbs=[
    {x:.2,y:.3,r:.3,spd:.0007},
    {x:.8,y:.6,r:.35,spd:.0009},
    {x:.5,y:.8,r:.28,spd:.0006},
  ];
  function draw(){
    ctx.clearRect(0,0,W,H);
    orbs.forEach((o,i)=>{
      o.x+=Math.sin(t*o.spd+i)*0.0003;
      o.y+=Math.cos(t*o.spd*1.3+i)*0.0002;
    });
    const alpha=isDark()?.06:.04;
    orbs.forEach(o=>{
      const grd=ctx.createRadialGradient(o.x*W,o.y*H,0,o.x*W,o.y*H,o.r*Math.min(W,H));
      grd.addColorStop(0,`rgba(${isDark()?'200,200,190':'80,80,70'},${alpha})`);
      grd.addColorStop(1,'transparent');
      ctx.fillStyle=grd;ctx.fillRect(0,0,W,H);
    });
    t++;requestAnimationFrame(draw);
  }
  resize();draw();
  window.addEventListener('resize',resize,true);
}
initPortfolioCanvas();

/* ════════════════════════════════
   BG 5: CV — Topographic Lines
════════════════════════════════ */
function drawCVTopo(){
  const svgEl=document.getElementById('cv-svg-bg');
  if(!svgEl)return;
  const isDark=document.documentElement.getAttribute('data-theme')==='dark';
  const W=svgEl.clientWidth||1080,H=svgEl.clientHeight||900;
  const clr=isDark?'rgba(240,239,232,0.06)':'rgba(17,17,16,0.05)';
  let d='';
  for(let i=0;i<12;i++){
    const y0=H*.1+i*(H*.08);
    const freq=.004+i*.0003,amp=30+i*8;
    let path=`M0 ${y0}`;
    for(let x=0;x<=W;x+=8){
      const y=y0+Math.sin(x*freq+i*1.5)*amp+Math.sin(x*.008+i)*15;
      path+=` L${x} ${y}`;
    }
    d+=`<path d="${path}" fill="none" stroke="${clr}" stroke-width="1.2"/>`;
  }
  svgEl.innerHTML=d;
}
window.addEventListener('load',drawCVTopo);
window.addEventListener('resize',drawCVTopo);

/* ════════════════════════════════
   SCROLL EFFECTS — PARALLAX
════════════════════════════════ */
function onScroll(){
  const sy=window.scrollY;

  // Parallax elements [data-par]
  document.querySelectorAll('[data-par]').forEach(el=>{
    const rect=el.getBoundingClientRect();
    const spd=parseFloat(el.dataset.par)||.2;
    const offset=(rect.top+rect.height/2-window.innerHeight/2)*spd;
    el.style.transform=`translateY(${offset}px)`;
  });

  // Home — paper grid moves slower
  const homePaper=document.querySelector('.home-paper');
  if(homePaper)homePaper.style.transform=`translateY(${sy*.3}px)`;

  // About — sheets parallax
  const aboutSheets=document.querySelectorAll('.paper-fold');
  aboutSheets.forEach((s,i)=>{
    const base=parseFloat(s.style.top)||0;
    s.style.transform=(s.style.transform||'').replace(/translateY\([^)]*\)/,'')+` translateY(${sy*.08*(i%2===0?1:-1)}px)`;
  });

  // Skills number float
  const skNum=document.querySelector('.sk-num');
  if(skNum){
    const rect=skNum.closest('section').getBoundingClientRect();
    skNum.style.transform=`translateY(${rect.top*.08}px)`;
  }

  // Portfolio tiles tilt on scroll
  const tiles=document.querySelectorAll('.tile');
  tiles.forEach((t,i)=>{
    const rect=t.getBoundingClientRect();
    const pct=(rect.top+rect.height/2-window.innerHeight/2)/window.innerHeight;
    const dir=i%2===0?1:-1;
    t.querySelector('.t-ph').style.transform=`translateY(${pct*18*dir}px)`;
  });

  // CV topo scroll
  const cvEl=document.getElementById('cv-svg-bg');
  if(cvEl){const r=cvEl.closest('section').getBoundingClientRect();cvEl.style.transform=`translateY(${r.top*.12}px)`}
}
window.addEventListener('scroll',onScroll,{passive:true});

/* ── TILE SPOTLIGHT ── */
document.querySelectorAll('.tile').forEach(tile=>{
  const spot=tile.querySelector('.tile-spot');
  tile.addEventListener('mousemove',e=>{
    const r=tile.getBoundingClientRect();
    spot.style.left=(e.clientX-r.left)+'px';
    spot.style.top=(e.clientY-r.top)+'px';
  });
});

/* ── REVEAL ── */
const rvObs=new IntersectionObserver(ens=>{ens.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in')})},{threshold:.07});
document.querySelectorAll('.rv,.rv-l,.rv-r').forEach(el=>rvObs.observe(el));

/* ── SKILL BARS ── */
const sbObs=new IntersectionObserver(ens=>{ens.forEach(e=>{if(e.isIntersecting){e.target.querySelectorAll('.sk-fill').forEach(f=>{f.style.transform=`scaleX(${f.dataset.w||.5})`;f.classList.add('on')})}})},{threshold:.2});
document.querySelectorAll('.sk-group').forEach(g=>sbObs.observe(g));

/* ── LANYARD PHYSICS ── */
(function(){
  const card=document.getElementById('lCard');
  const rope=document.getElementById('lRope');
  if(!card)return;
  let drag=false,sy=0,posY=0,velY=0,rot=0,lastY=0,swT=0;
  const maxS=20,damp=.87,stiff=.11;
  function lerp(a,b,t){return a+(b-a)*t}
  function step(){
    if(!drag){velY+=(-posY)*stiff;velY*=damp;posY+=velY;rot=lerp(rot,0,.07)+velY*.35;rot=Math.max(-maxS,Math.min(maxS,rot))}
    card.style.transform=`translateY(${posY}px) rotate(${rot}deg)`;
    rope.style.transform=`rotate(${rot*.28}deg)`;
    requestAnimationFrame(step);
  }
  function down(e){drag=true;card.style.cursor='grabbing';sy=e.touches?e.touches[0].clientY:e.clientY;lastY=sy}
  function move(e){if(!drag)return;const cy=e.touches?e.touches[0].clientY:e.clientY;velY=cy-lastY;lastY=cy;posY=Math.max(-60,Math.min(130,cy-sy));rot=posY*.14}
  function up(){drag=false;card.style.cursor='grab'}
  card.addEventListener('mousedown',down);card.addEventListener('touchstart',down,{passive:true});
  window.addEventListener('mousemove',move);window.addEventListener('touchmove',move,{passive:true});
  window.addEventListener('mouseup',up);window.addEventListener('touchend',up);
  function idle(){swT+=.012;if(!drag&&Math.abs(posY)<2&&Math.abs(velY)<.2){card.style.transform=`translateY(${Math.sin(swT)*1.4}px) rotate(${Math.sin(swT)*.7}deg)`;rope.style.transform=`rotate(${Math.sin(swT)*.18}deg)`}requestAnimationFrame(idle)}
  requestAnimationFrame(step);requestAnimationFrame(idle);
})();
</script>
</body>
</html>