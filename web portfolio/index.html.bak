</div>

<!-- ═══ HOME ═══ -->
<section id="home">
  <canvas id="home-canvas"></canvas>
  <div class="home-paper"></div>
  <div class="sec-inner">
    <div class="h-left rv-l">
      <div class="h-eyebrow" data-i18n="havl">Tersedia untuk Peluang Baru</div>
      <div class="h-name">Azahwa<br><em>Celina Latifa</em></div>
      <div style="margin-top:1rem"><div class="h-tag" data-i18n="htag">Calon Web Developer & IT Enthusiast<br>Tertarik pada UI/UX dan Jaringan</div></div>
    </div>
    <!-- LANYARD CENTER -->
    <div class="lanyard-wrap rv" id="lWrap">
      <div class="l-hook"><svg viewBox="0 0 20 24" fill="none"><path d="M10 2C10 2 4 2 4 8C4 11 6 13 10 13C14 13 16 11 16 8C16 2 10 2 10 2Z" stroke="#b8b8b0" stroke-width="1.5" fill="none"/><rect x="9" y="12" width="2" height="6" rx="1" fill="#b8b8b0"/></svg></div>
      <div class="l-rope" id="lRope"></div>
      <div class="l-clip"></div>
      <div class="l-card" id="lCard">
        <div class="l-stripe"><span class="l-stripe-txt">STUDENT ID · SIJA</span><div class="l-dots"><div class="l-dot"></div><div class="l-dot"></div><div class="l-dot"></div></div></div>
        <div class="l-ph">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
          <span>Foto Kamu</span>
        </div>
        <div class="l-foot">
          <div><div class="l-fn">Azahwa Celina Latifa</div><div class="l-fr">WEB DEV · DESIGNER</div></div>
          <div class="l-chip"><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div></div>
        </div>
      </div>
      <div style="margin-top:.75rem;text-align:center"><span class="sv-tag" style="font-size:8px" data-i18n="drag">↕ Tarik kartu</span></div>
    </div>
    <div class="h-right rv-r">
      <p class="h-desc" data-i18n="hdesc">Saya adalah siswa SMK yang bersemangat dalam dunia teknologi dan pengembangan web. Saya percaya desain yang baik bukan hanya soal tampilan, tapi tentang pengalaman. Terus belajar, terus berkarya.</p>
      <div class="h-meta"><span class="sv-tag" data-i18n="t1"> Semarang</span><span class="sv-tag" data-i18n="t2"> SMK SIJA</span><span class="sv-tag" data-i18n="t3"> Web Dev</span></div>
      <div class="h-cta">
        <a href="#portfolio" class="sv-btn"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg><span data-i18n="bw">Lihat Karya</span></a>
        <a href="#cv" class="sv-btn" style="background:transparent;border-color:var(--border);color:var(--text)"><span data-i18n="bc">Unduh CV</span></a>
      </div>
    </div>
  </div>
  <div class="h-scroll"><span data-i18n="sc">scroll</span><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg></div>
</section>

<!-- ═══ ABOUT ═══ -->
<section id="about">
  <div id="about-bg"></div>
  <div class="sec-inner">
    <div class="a-head-row rv">
      <div class="a-issue" data-i18n="lab_a">001 — Tentang Saya</div>
      <div class="a-big" data-i18n="a_ttl">Mengenal<br><em>Lebih Dekat</em></div>
      <div class="a-sub" data-i18n="a_sub">Seorang pelajar, desainer, dan pembangun hal-hal digital.</div>
    </div>
    <div class="a-cols rv">
      <div>
        <div class="a-ct" data-i18n="af_t">Keluarga & Latar</div>
        <p class="a-p" data-i18n="af_p">Lahir dan besar di Semarang, Jawa Barat. Anak pertama dari dua bersaudara dalam keluarga sederhana yang mengutamakan pendidikan. Ayah saya seorang teknisi — itulah awal ketertarikan saya pada dunia teknis.</p>
        <div class="a-ct" style="margin-top:2rem" data-i18n="ae_t">Pendidikan</div>
        <div class="a-edu"><div class="a-school">SMK Negeri 7 Semarang</div><div class="a-esub">Teknik Komputer &amp; Jaringan · 2022 – Sekarang</div></div>
        <div class="a-edu"><div class="a-school">SMP Negeri 5 Semarang</div><div class="a-esub">2019 – 2022</div></div>
        <div class="a-edu"><div class="a-school">SD Negeri Sukorejo 1</div><div class="a-esub">2013 – 2019</div></div>
      </div>
      <div>
        <div class="a-ct" data-i18n="ahob_t">Hobi &amp; Minat</div>
        <div class="a-hob"><span class="sv-dot"></span><span data-i18n="h1">Desain grafis &amp; UI/UX exploration</span></div>
        <div class="a-hob"><span class="sv-dot"></span><span data-i18n="h2">Membaca artikel teknologi</span></div>
        <div class="a-hob"><span class="sv-dot"></span><span data-i18n="h3">Hackathon &amp; lomba IT</span></div>
        <div class="a-hob"><span class="sv-dot"></span><span data-i18n="h4">Fotografi urban</span></div>
        <div class="a-hob"><span class="sv-dot"></span><span data-i18n="h5">Gitar akustik</span></div>
        <div class="a-ct" style="margin-top:2rem" data-i18n="ac_t">Tujuan Karier</div>
        <p class="a-p" data-i18n="ac_p">Menjadi Full-Stack Developer yang menciptakan solusi digital berdampak, berkontribusi di perusahaan teknologi inovatif sambil terus bertumbuh.</p>
      </div>
      <div>
        <div class="a-ct" data-i18n="astr_t">Kelebihan Diri</div>
        <div style="margin-bottom:1rem">
          <div style="font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.12em;color:var(--text3);margin-bottom:.5rem" data-i18n="sft">SOFT SKILLS</div>
          <div class="a-sw"><span class="sv-tag" data-i18n="ss1">Cepat Belajar</span><span class="sv-tag" data-i18n="ss2">Kreatif</span><span class="sv-tag" data-i18n="ss3">Detail-Oriented</span><span class="sv-tag" data-i18n="ss4">Kerja Tim</span><span class="sv-tag" data-i18n="ss5">Adaptif</span><span class="sv-tag" data-i18n="ss6">Komunikatif</span></div>
        </div>
        <div>
          <div style="font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.12em;color:var(--text3);margin-bottom:.5rem" data-i18n="hrd">HARD SKILLS</div>
          <div class="a-sw"><span class="sv-tag">HTML &amp; CSS</span><span class="sv-tag">JavaScript</span><span class="sv-tag">Cisco</span><span class="sv-tag">Canva</span><span class="sv-tag">Photoshop</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

